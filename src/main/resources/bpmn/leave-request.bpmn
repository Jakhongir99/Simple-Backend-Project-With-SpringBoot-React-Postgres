                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_Leave"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="LeaveProcess" isExecutable="false">
    <bpmn:startEvent id="L_Start" name="Ta&#39;til so&#39;raldi">
      <bpmn:outgoing>LF_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="L_Manager" name="Rahbar ko&#39;rib chiqadi">
      <bpmn:incoming>LF_1</bpmn:incoming>
      <bpmn:outgoing>LF_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="L_Gw" name="Qaror">
      <bpmn:incoming>LF_2</bpmn:incoming>
      <bpmn:outgoing>LF_3</bpmn:outgoing>
      <bpmn:outgoing>LF_4</bpmn:outgoing>
