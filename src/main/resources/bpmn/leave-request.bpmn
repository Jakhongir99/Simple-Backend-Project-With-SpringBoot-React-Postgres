        <bpmndi:BPMNLabel><dc:Bounds x="425" y="363" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="LF_1_di" bpmnElement="LF_1">
