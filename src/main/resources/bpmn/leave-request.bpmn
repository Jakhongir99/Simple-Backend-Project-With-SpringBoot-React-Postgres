    <bpmn:endEvent id="L_Rejected" name="Rad etildi">
      <bpmn:incoming>LF_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="LF_1" sourceRef="L_Start" targetRef="L_Manager" />
    <bpmn:sequenceFlow id="LF_2" sourceRef="L_Manager" targetRef="L_Gw" />
    <bpmn:sequenceFlow id="LF_3" name="Ha" sourceRef="L_Gw" targetRef="L_Approved" />
    <bpmn:sequenceFlow id="LF_4" name="Yo&#39;q" sourceRef="L_Gw" targetRef="L_Rejected" />
  </bpmn:process>
